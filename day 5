#include <iostream>
using namespace std;

int add (int a, int b){
return a+b;
}

int add (int a, int b, int c){
return a+b+c;
}

int add (int a, int b, int c, int d){
return a+b+c+d;
}

double add (double a, double b){
return a+b;
}

int main()
{
    cout<<add(2,5)<<"\n";
    
    cout<<add(2,5,6)<<"\n";
    
    cout<<add(2,5,8,2)<<"\n";
    
    cout<<add(2.8,5.3)<<"\n";
    return 0;
}

