#include <iostream>
using namespace std;

int main()
{
    int n;
    cin>>n;
    bool isprime=true;
    if(n<2){
             isprime=false;
           }
    else{
        for(int i=2;i<n;i++){
            if(n%i==0)
            {isprime=false;
            break;}
            }
    }
    if (isprime){cout<<"it is a prime no";}
    else {cout<<"not prime";}
    return 0;
}
